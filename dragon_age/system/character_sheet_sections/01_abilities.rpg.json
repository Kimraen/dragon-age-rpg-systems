{
  "type": "CharacterSheetSection",
  "id": "abilities",
  "view": {
    "id": "abilities_sheet_root",
    "type": "list",
    "subviews": [
      {
        "id": "core_abilities_section",
        "type": "section",
        "header": [
          { "id": "core_abilities_header", "type": "text", "text": { "type": "constant", "value_type": "string", "value": "Core Abilities" }, "style": "headline" }
        ],
        "content": [
          { "id": "com_block", "type": "stat", "stat": "communication", "style": "block", "always_show_sign": true, "min_value_allowed": -2, "max_value_allowed": 8 },
          { "id": "con_block", "type": "stat", "stat": "constitution",  "style": "block", "always_show_sign": true, "min_value_allowed": -2, "max_value_allowed": 8 },
          { "id": "cun_block", "type": "stat", "stat": "cunning",       "style": "block", "always_show_sign": true, "min_value_allowed": -2, "max_value_allowed": 8 },
          { "id": "dex_block", "type": "stat", "stat": "dexterity",     "style": "block", "always_show_sign": true, "min_value_allowed": -2, "max_value_allowed": 8 },
          { "id": "mag_block", "type": "stat", "stat": "magic",         "style": "block", "always_show_sign": true, "min_value_allowed": -2, "max_value_allowed": 8 },
          { "id": "per_block", "type": "stat", "stat": "perception",    "style": "block", "always_show_sign": true, "min_value_allowed": -2, "max_value_allowed": 8 },
          { "id": "str_block", "type": "stat", "stat": "strength",      "style": "block", "always_show_sign": true, "min_value_allowed": -2, "max_value_allowed": 8 },
          { "id": "wil_block", "type": "stat", "stat": "willpower",     "style": "block", "always_show_sign": true, "min_value_allowed": -2, "max_value_allowed": 8 }
        ],
        "content_item_min_width": 72,
        "show_divider": false
      },
      {
        "id": "focuses_note",
        "type": "text",
        "text": { "type": "constant", "value_type": "string", "value": "A focus grants +2 to the ability for tests within that specialty." },
        "style": "caption"
      },
      {
        "id": "com_focuses_collapsible",
        "type": "collapsible",
        "title": { "type": "constant", "value_type": "string", "value": "Communication Focuses" },
        "subtitle": { "type": "constant", "value_type": "string", "value": "Bargaining, Deception, Etiquette, Leadership, Persuasion..." },
        "start_expanded": false,
        "subviews": [
          { "id": "f_com_animal_handling", "type": "checkbox", "stat": "focus_com_animal_handling", "label": { "type": "constant", "value_type": "string", "value": "Animal Handling" }, "should_auto_save": true },
          { "id": "f_com_bargaining",      "type": "checkbox", "stat": "focus_com_bargaining",      "label": { "type": "constant", "value_type": "string", "value": "Bargaining" },      "should_auto_save": true },
          { "id": "f_com_deception",       "type": "checkbox", "stat": "focus_com_deception",       "label": { "type": "constant", "value_type": "string", "value": "Deception" },       "should_auto_save": true },
          { "id": "f_com_disguise",        "type": "checkbox", "stat": "focus_com_disguise",        "label": { "type": "constant", "value_type": "string", "value": "Disguise" },        "should_auto_save": true },

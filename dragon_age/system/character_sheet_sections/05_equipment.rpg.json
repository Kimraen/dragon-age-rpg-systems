{
  "type": "CharacterSheetSection",
  "id": "equipment",
  "view": {
    "id": "equipment_root",
    "type": "list",
    "subviews": [
      {
        "id": "currency_section",
        "type": "section",
        "header": [
          { "id": "currency_header", "type": "text", "text": { "type": "constant", "value_type": "string", "value": "Currency" }, "style": "section" }
        ],
        "content": [
          { "id": "gold_stat",   "type": "stat", "stat": "gold_pieces",   "style": "block" },
          { "id": "silver_stat", "type": "stat", "stat": "silver_pieces", "style": "block" },
          { "id": "copper_stat", "type": "stat", "stat": "copper_pieces", "style": "block" }
        ],
        "content_item_min_width": 72,
        "show_divider": true
      },
      {
        "id": "weapons_section",
        "type": "section",
        "header": [
          { "id": "weapons_header", "type": "text", "text": { "type": "constant", "value_type": "string", "value": "Weapons" }, "style": "section" }
        ],
        "content": [
          {
            "id": "weapons_list_view",
            "type": "resourceArray",
            "resource_id": "weapon",
            "stat": "weapons",
            "view_type": "list",
            "pop_up_type": "bottomSheet",
            "pop_up_button_text": { "type": "constant", "value_type": "string", "value": "Add Weapon" }
          }
        ]
      },
      {
        "id": "armor_section",
        "type": "section",
        "header": [
          { "id": "armor_header", "type": "text", "text": { "type": "constant", "value_type": "string", "value": "Armor & Shields" }, "style": "section" }
        ],
        "content": [
          {
            "id": "armor_list_view",
            "type": "resourceArray",
            "resource_id": "armor",
            "stat": "armors",
            "view_type": "list",
            "pop_up_type": "bottomSheet",
            "pop_up_button_text": { "type": "constant", "value_type": "string", "value": "Add Armor" }
          }
        ]
      },
      {
        "id": "items_section",
        "type": "section",
        "header": [
          { "id": "items_header", "type": "text", "text": { "type": "constant", "value_type": "string", "value": "Other Equipment" }, "style": "section" }
        ],
        "content": [
          {
            "id": "items_list_view",
            "type": "resourceArray",
            "resource_id": "item",
            "stat": "items",
            "view_type": "list",
            "pop_up_type": "bottomSheet",
            "pop_up_button_text": { "type": "constant", "value_type": "string", "value": "Add Item" }
          }
        ]
      }
    ]
  }
}

{
  "type": "CharacterSheetSection",
  "id": "combat",
  "view": {
    "id": "combat_root",
    "type": "list",
    "subviews": [
      {
        "id": "health_section",
        "type": "section",
        "header": [
          { "id": "health_header", "type": "text", "text": { "type": "constant", "value_type": "string", "value": "Hit Points" }, "style": "section" }
        ],
        "content": [
          {
            "id": "hp_ticker",
            "type": "ticker",
            "stat": "current_health",
            "label": { "type": "constant", "value_type": "string", "value": "Current HP" },
            "min_value_allowed": 0,
            "calculated_max_value_allowed": { "type": "stat", "stat": "max_health" },
            "should_auto_save": true,
            "button_look": "upDown"
          },
          { "id": "max_hp_stat", "type": "stat", "stat": "max_health", "style": "list", "min_value_allowed": 1, "max_value_allowed": 500 }
        ],
        "show_divider": true
      },
      {
        "id": "mana_section",
        "type": "section",
        "is_visible": {
          "type": "equals",
          "components": {
            "type": "list",
            "components": [
              { "type": "stat", "stat": "character_class" },
              { "type": "constant", "value_type": "string", "value": "mage" }
            ]
          }
        },
        "header": [
          { "id": "mana_header", "type": "text", "text": { "type": "constant", "value_type": "string", "value": "Mana" }, "style": "section" }
        ],
        "content": [
          {
            "id": "mana_ticker",
            "type": "ticker",
            "stat": "current_mana",
            "label": { "type": "constant", "value_type": "string", "value": "Current Mana" },
            "min_value_allowed": 0,
            "calculated_max_value_allowed": { "type": "stat", "stat": "max_mana" },
            "should_auto_save": true,
            "button_look": "upDown"
          },
          { "id": "max_mana_stat", "type": "stat", "stat": "max_mana", "style": "list", "min_value_allowed": 0, "max_value_allowed": 500 }
        ],
        "show_divider": true
      },
      {
        "id": "defense_section",
        "type": "section",
        "header": [
          { "id": "defense_header", "type": "text", "text": { "type": "constant", "value_type": "string", "value": "Defense & Movement" }, "style": "section" }
        ],
        "content": [
          { "id": "defense_stat", "type": "stat", "stat": "defense", "style": "block" },
          { "id": "speed_stat",   "type": "stat", "stat": "speed",   "style": "block" }
        ],
        "content_item_min_width": 100,
        "show_divider": true
      },
      {
        "id": "armor_section",
        "type": "section",
        "header": [
          { "id": "armor_header", "type": "text", "text": { "type": "constant", "value_type": "string", "value": "Armor" }, "style": "section" }
        ],
        "content": [
          { "id": "ar_stat",      "type": "stat", "stat": "armor_rating",  "style": "list", "min_value_allowed": 0, "max_value_allowed": 20 },
          { "id": "ap_stat",      "type": "stat", "stat": "armor_penalty", "style": "list", "min_value_allowed": 0, "max_value_allowed": 10 }
        ],
        "show_divider": true
      },
      {
        "id": "magic_resistance_section",
        "type": "section",
        "header": [
          { "id": "mr_header", "type": "text", "text": { "type": "constant", "value_type": "string", "value": "Magic Resistance" }, "style": "section" }
        ],
        "content": [
          { "id": "mr_stat", "type": "stat", "stat": "magic_resistance_mod", "style": "list", "always_show_sign": true },
          {
            "id": "mr_note",
            "type": "text",
            "text": { "type": "constant", "value_type": "string", "value": "Dwarves & Qunari: +2 | Qunari/Tal-Vashoth: -1 to resist spells. Set above as net modifier." },
            "style": "caption"
          }
        ],
        "show_divider": true
      },
      {
        "id": "weapon_groups_section",
        "type": "section",
        "collapsible": true,
        "start_collapsed": true,
        "header": [
          { "id": "wg_header", "type": "text", "text": { "type": "constant", "value_type": "string", "value": "Weapon Groups" }, "style": "section" }
        ],
        "content": [
          { "id": "wg_bludgeons",    "type": "checkbox", "stat": "weapon_group_bludgeons",    "label": { "type": "constant", "value_type": "string", "value": "Bludgeons" },    "should_auto_save": true },
          { "id": "wg_bows",         "type": "checkbox", "stat": "weapon_group_bows",         "label": { "type": "constant", "value_type": "string", "value": "Bows" },         "should_auto_save": true },
          { "id": "wg_brawling",     "type": "checkbox", "stat": "weapon_group_brawling",     "label": { "type": "constant", "value_type": "string", "value": "Brawling" },     "should_auto_save": true },
          { "id": "wg_dueling",      "type": "checkbox", "stat": "weapon_group_dueling",      "label": { "type": "constant", "value_type": "string", "value": "Dueling" },      "should_auto_save": true },
          { "id": "wg_heavy_blades", "type": "checkbox", "stat": "weapon_group_heavy_blades", "label": { "type": "constant", "value_type": "string", "value": "Heavy Blades" }, "should_auto_save": true },
          { "id": "wg_light_blades", "type": "checkbox", "stat": "weapon_group_light_blades", "label": { "type": "constant", "value_type": "string", "value": "Light Blades" }, "should_auto_save": true },
          { "id": "wg_lances",       "type": "checkbox", "stat": "weapon_group_lances",       "label": { "type": "constant", "value_type": "string", "value": "Lances" },       "should_auto_save": true },
          { "id": "wg_polearms",     "type": "checkbox", "stat": "weapon_group_polearms",     "label": { "type": "constant", "value_type": "string", "value": "Polearms" },     "should_auto_save": true },
          { "id": "wg_staves",       "type": "checkbox", "stat": "weapon_group_staves",       "label": { "type": "constant", "value_type": "string", "value": "Staves" },       "should_auto_save": true },
          { "id": "wg_thrown",       "type": "checkbox", "stat": "weapon_group_thrown",       "label": { "type": "constant", "value_type": "string", "value": "Thrown" },       "should_auto_save": true }
        ]
      }
    ]
  }
}

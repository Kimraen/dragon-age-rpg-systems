// ============================================================
// COMBAT STATS
// ============================================================

@party_visible
base integer current_health(name = "Health", abbreviation = "HP") = 20;

@party_visible
base integer max_health(name = "Max Health") = 20;

base integer current_mana(name = "Mana", abbreviation = "MP") = 0;
base integer max_mana(name = "Max Mana") = 0;

base integer armor_rating(name = "Armor Rating", abbreviation = "AR") = 0;
base integer armor_penalty(name = "Armor Penalty") = 0;

// Defense = 10 + Dexterity  (armor does NOT reduce defense, it reduces damage)
@party_visible
calc integer defense(name = "Defense", abbreviation = "DEF") = 10 + dexterity;

// Speed = 10 + Dexterity, reduced by heavy armor's armor penalty
@party_visible
calc integer speed(name = "Speed") = 10 + dexterity - armor_penalty;

// Magic Resistance: Dwarves/Qunari gain +2 on tests to resist spells.
// Qunari/Tal-Vashoth: -1 to resist spells. Track here as a modifier.
base integer magic_resistance_mod(name = "Magic Resistance Mod") = 0;


// ============================================================
// WEAPON GROUPS  (training allows use without penalty)
// ============================================================

base bool weapon_group_bludgeons(name = "Bludgeons") = false;
base bool weapon_group_bows(name = "Bows") = false;
base bool weapon_group_brawling(name = "Brawling") = false;
base bool weapon_group_dueling(name = "Dueling") = false;
base bool weapon_group_heavy_blades(name = "Heavy Blades") = false;
base bool weapon_group_light_blades(name = "Light Blades") = false;
base bool weapon_group_lances(name = "Lances") = false;
base bool weapon_group_polearms(name = "Polearms") = false;
base bool weapon_group_staves(name = "Staves") = false;
base bool weapon_group_thrown(name = "Thrown") = false;


// ============================================================
// CURRENCY
// ============================================================

base integer gold_pieces(name = "Gold", abbreviation = "GP") = 0;
base integer silver_pieces(name = "Silver", abbreviation = "SP") = 0;
base integer copper_pieces(name = "Copper", abbreviation = "CP") = 0;


// ============================================================
// REPUTATION & MISC
// ============================================================

base integer reputation(name = "Reputation") = 0;


// ============================================================
// RESOURCE COLLECTIONS
// ============================================================

base resource<spell>[] spells(name = "Spells") = [];
base resource<talent>[] talents(name = "Talents") = [];
base resource<weapon>[] weapons(name = "Weapons") = [];
base resource<armor>[] armors(name = "Armor") = [];
base resource<item>[] items(name = "Equipment") = [];


// ============================================================
// BIOGRAPHY & NOTES
// ============================================================

base string goals(name = "Goals") = "";
base string ties(name = "Ties") = "";
base string background_story(name = "Background Story") = "";
base string appearance(name = "Appearance") = "";
base string notes(name = "Notes") = "";

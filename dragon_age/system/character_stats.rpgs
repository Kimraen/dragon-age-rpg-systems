// ============================================================
// DRAGON AGE RPG — CHARACTER STATS
// ============================================================

// ---- BASIC IDENTITY ----

@party_visible
base string character_name(name = "Name") = "";

base string photo(name = "Photo") = "";
base string pronouns(name = "Pronouns") = "";
base string age(name = "Age") = "";

@party_visible
base integer level(name = "Level") = 1;

base integer experience(name = "Experience", abbreviation = "XP") = 0;

@party_visible
base string character_class(name = "Class") = "";

base string background(name = "Background") = "";
base string race(name = "Race") = "";


// ============================================================
// CORE ABILITIES  (range: -2 to 4, higher at later levels)
// ============================================================

@party_visible
base integer communication(name = "Communication", abbreviation = "COM") = 1;

@party_visible
base integer constitution(name = "Constitution", abbreviation = "CON") = 1;

@party_visible
base integer cunning(name = "Cunning", abbreviation = "CUN") = 1;

@party_visible
base integer dexterity(name = "Dexterity", abbreviation = "DEX") = 1;

@party_visible
base integer magic(name = "Magic", abbreviation = "MAG") = 1;

@party_visible
base integer perception(name = "Perception", abbreviation = "PER") = 1;

@party_visible
base integer strength(name = "Strength", abbreviation = "STR") = 1;

@party_visible
base integer willpower(name = "Willpower", abbreviation = "WIL") = 1;


// ============================================================
// ABILITY FOCUSES  (each grants +2 to the relevant ability)
// ============================================================


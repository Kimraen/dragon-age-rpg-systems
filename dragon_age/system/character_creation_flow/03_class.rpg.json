{
  "type": "CharacterCreationPage",
  "title": "Class",
  "view": {
    "id": "class_creation_root",
    "type": "list",
    "subviews": [
      {
        "id": "class_instruction",
        "type": "text",
        "text": { "type": "constant", "value_type": "string", "value": "Choose your class. Your background determines which classes are available to you. Mages use Magic and Willpower, Rogues use Dexterity and Communication, and Warriors use Strength and Constitution." },
        "style": "text"
      },
      {
        "id": "class_select_section",
        "type": "section",
        "header": [
          { "id": "class_select_header", "type": "text", "text": { "type": "constant", "value_type": "string", "value": "Choose Class" }, "style": "section" }
        ],
        "content": [
          {
            "id": "class_select",
            "type": "select",
            "stat": "character_class",
            "options": "da_class",
            "style": "list"
          }
        ]
      },
      {
        "id": "health_section",
        "type": "section",
        "header": [
          { "id": "health_header", "type": "text", "text": { "type": "constant", "value_type": "string", "value": "Starting Health" }, "style": "section" }
        ],
        "content": [
          {
            "id": "health_instruction",
            "type": "text",
            "text": { "type": "constant", "value_type": "string", "value": "Warrior: 30 + (Constitution \u00d7 5) | Rogue: 25 + (Constitution \u00d7 4) | Mage: 20 + (Constitution \u00d7 3). Set your Max Health and Current Health accordingly." },
            "style": "text"
          },
          { "id": "max_health_ticker", "type": "ticker", "stat": "max_health", "label": { "type": "constant", "value_type": "string", "value": "Max Health" }, "min_value_allowed": 1, "max_value_allowed": 500, "should_auto_save": true },
          { "id": "cur_health_ticker", "type": "ticker", "stat": "current_health", "label": { "type": "constant", "value_type": "string", "value": "Current Health" }, "min_value_allowed": 0, "max_value_allowed": 500, "should_auto_save": true }
        ]
      },
      {
        "id": "mana_section",
        "type": "section",
        "is_visible": {
          "type": "equals",
          "components": {
            "type": "list",
            "components": [
              { "type": "stat", "stat": "character_class" },
              { "type": "constant", "value_type": "string", "value": "mage" }
            ]
          }
        },
        "header": [
          { "id": "mana_header", "type": "text", "text": { "type": "constant", "value_type": "string", "value": "Mana Points" }, "style": "section" }
        ],
        "content": [
          {
            "id": "mana_instruction",
            "type": "text",
            "text": { "type": "constant", "value_type": "string", "value": "Starting Mana = (Magic \u00d7 10) + (Willpower \u00d7 5). Set your Max Mana and Current Mana below." },
            "style": "text"
          },
          { "id": "max_mana_ticker", "type": "ticker", "stat": "max_mana", "label": { "type": "constant", "value_type": "string", "value": "Max Mana" }, "min_value_allowed": 0, "max_value_allowed": 500, "should_auto_save": true },
          { "id": "cur_mana_ticker", "type": "ticker", "stat": "current_mana", "label": { "type": "constant", "value_type": "string", "value": "Current Mana" }, "min_value_allowed": 0, "max_value_allowed": 500, "should_auto_save": true }
        ]
      },
      {
        "id": "weapon_groups_section",
        "type": "section",
        "header": [
          { "id": "wg_header", "type": "text", "text": { "type": "constant", "value_type": "string", "value": "Starting Weapon Groups" }, "style": "section" }
        ],
        "content": [
          {
            "id": "wg_instruction",
            "type": "text",
            "text": { "type": "constant", "value_type": "string", "value": "Check all weapon groups your class grants you. Refer to your class description for the full list." },
            "style": "text"
          },
          { "id": "wg_bludgeons",    "type": "checkbox", "stat": "weapon_group_bludgeons",    "label": { "type": "constant", "value_type": "string", "value": "Bludgeons" },    "should_auto_save": true },
          { "id": "wg_bows",         "type": "checkbox", "stat": "weapon_group_bows",         "label": { "type": "constant", "value_type": "string", "value": "Bows" },         "should_auto_save": true },
          { "id": "wg_brawling",     "type": "checkbox", "stat": "weapon_group_brawling",     "label": { "type": "constant", "value_type": "string", "value": "Brawling" },     "should_auto_save": true },
          { "id": "wg_dueling",      "type": "checkbox", "stat": "weapon_group_dueling",      "label": { "type": "constant", "value_type": "string", "value": "Dueling" },      "should_auto_save": true },
          { "id": "wg_heavy_blades", "type": "checkbox", "stat": "weapon_group_heavy_blades", "label": { "type": "constant", "value_type": "string", "value": "Heavy Blades" }, "should_auto_save": true },
          { "id": "wg_light_blades", "type": "checkbox", "stat": "weapon_group_light_blades", "label": { "type": "constant", "value_type": "string", "value": "Light Blades" }, "should_auto_save": true },
          { "id": "wg_lances",       "type": "checkbox", "stat": "weapon_group_lances",       "label": { "type": "constant", "value_type": "string", "value": "Lances" },       "should_auto_save": true },
          { "id": "wg_polearms",     "type": "checkbox", "stat": "weapon_group_polearms",     "label": { "type": "constant", "value_type": "string", "value": "Polearms" },     "should_auto_save": true },
          { "id": "wg_staves",       "type": "checkbox", "stat": "weapon_group_staves",       "label": { "type": "constant", "value_type": "string", "value": "Staves" },       "should_auto_save": true },
          { "id": "wg_thrown",       "type": "checkbox", "stat": "weapon_group_thrown",       "label": { "type": "constant", "value_type": "string", "value": "Thrown" },       "should_auto_save": true }
        ]
      }
    ]
  }
}
